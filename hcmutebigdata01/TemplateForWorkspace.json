		{
			"name": "[concat(parameters('workspaceName'), '/SQL 6 explore')]",
			"type": "Microsoft.Synapse/workspaces/sqlscripts",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"content": {
					"query": "IF OBJECT_ID('dbo.PassengerCountStats', 'U') IS NOT NULL\n    DROP TABLE dbo.PassengerCountStats;\nGO\n\nSELECT \n    passengerCount as PassengerCount,\n    SUM(tripDistance) as SumTripDistance_miles,\n    AVG(tripDistance) as AvgTripDistance_miles\nINTO dbo.PassengerCountStats\nFROM dbo.YellowTaxi2019\nWHERE tripDistance > 0 AND passengerCount > 0\nGROUP BY passengerCount;\nGO\n\nSELECT * FROM dbo.PassengerCountStats\nORDER BY PassengerCount;",
					"metadata": {
						"language": "sql"
					},
					"currentConnection": {
						"databaseName": "sqlpoolgr8",
						"poolName": "sqlpoolgr8"
					},
					"resultLimit": 5000
				},
				"type": "SqlQuery"
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('workspaceName'), '/SQL copy data')]",
			"type": "Microsoft.Synapse/workspaces/sqlscripts",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"content": {
					"query": "IF NOT EXISTS (SELECT * FROM sys.objects O JOIN sys.schemas S ON O.schema_id = S.schema_id WHERE O.NAME = 'NYCTaxiTripSmall' AND O.TYPE = 'U' AND S.NAME = 'dbo')\nCREATE TABLE dbo.NYCTaxiTripSmall\n    (\n    [VendorID] bigint, [store_and_fwd_flag] nvarchar(1) NULL, [RatecodeID] float NULL, \n    [PULocationID] bigint NULL, [DOLocationID] bigint NULL, [passenger_count] float NULL, \n    [trip_distance] float NULL, [fare_amount] float NULL, [extra] float NULL, \n    [mta_tax] float NULL, [tip_amount] float NULL, [tolls_amount] float NULL, \n    [ehail_fee] float NULL, [improvement_surcharge] float NULL, [total_amount] float NULL, \n    [payment_type] float NULL, [trip_type] float NULL, [congestion_surcharge] float NULL\n    )\nWITH ( DISTRIBUTION = ROUND_ROBIN, CLUSTERED COLUMNSTORE INDEX )\nGO\nCOPY INTO dbo.NYCTaxiTripSmall\n(VendorID 1, store_and_fwd_flag 4, RatecodeID 5, PULocationID 6, DOLocationID 7, passenger_count 8, trip_distance 9, fare_amount 10, extra 11, mta_tax 12, tip_amount 13, tolls_amount 14, ehail_fee 15, improvement_surcharge 16, total_amount 17, payment_type 18, trip_type 19, congestion_surcharge 20)\nFROM 'https://dlhcmute.dfs.core.windows.net/data/synapse/workspaces/hcmutebigdata01/warehouse/nyctaxi.db/passengercountstatsnew/' \nWITH\n(\n    FILE_TYPE = 'PARQUET'\n    ,MAXERRORS = 0\n    ,IDENTITY_INSERT = 'OFF'\n    ,AUTO_CREATE_TABLE ='ON'\n)",
					"metadata": {
						"language": "sql"
					},
					"currentConnection": {
						"databaseName": "sqlpoolgr8",
						"poolName": "sqlpoolgr8"
					},
					"resultLimit": 5000
				},
				"type": "SqlQuery"
			},
			"dependsOn": []
		},
