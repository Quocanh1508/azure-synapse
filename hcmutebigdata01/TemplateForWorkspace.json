					"query": "\nSELECT\n    TOP 100 *\nFROM\n    OPENROWSET(\n        BULK 'https://dlhcmute.dfs.core.windows.net/data/NYCTaxi/PassengerCountStats_parquetformat/**',\n        FORMAT = 'PARQUET'\n    ) AS [result]\n",
