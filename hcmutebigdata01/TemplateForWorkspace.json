			"type": "Microsoft.Synapse/workspaces/sqlscripts",
			"apiVersion": "2019-06-01-preview",
			"properties": {
				"content": {
					"query": "SELECT TOP 100 *\nFROM OPENROWSET(\n    BULK '/data/taxi_zone_lookup.csv',\n    DATA_SOURCE = 'Datasrc',    \n    FORMAT = 'CSV',\n    PARSER_VERSION = '2.0',\n    HEADER_ROW = TRUE                 \n) AS [Result];",
					"metadata": {
						"language": "sql"
					},
					"currentConnection": {
						"databaseName": "NYCTaxiDB",
						"poolName": "Built-in"
					},
					"resultLimit": 5000
				},
				"type": "SqlQuery"
			},
			"dependsOn": []
		},
