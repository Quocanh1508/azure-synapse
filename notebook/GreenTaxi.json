		"cells": [
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql import SparkSession\n",
					"from pyspark.sql.functions import col\n",
					"\n",
					"\n",
					"spark = SparkSession.builder.getOrCreate()"
				],
				"execution_count": 1
			},
			{
				"cell_type": "markdown",
				"metadata": {
					"nteract": {
						"transient": {
							"deleting": false
						}
					}
				},
				"source": [
					"B2 - Load dataset từ Data Lake\n",
					""
				]
			},
			{
				"cell_type": "code",
				"source": [
					"df = spark.read.parquet(\n",
					"\"wasbs://nyctlc@azureopendatastorage.blob.core.windows.net/green/puYear=2019/puMonth=1/*.parquet\"\n",
					")"
				],
				"execution_count": 3
			},
			{
				"cell_type": "markdown",
				"metadata": {
					"nteract": {
						"transient": {
							"deleting": false
						}
					}
				},
				"source": [
					"B3 - Kiểm tra dữ liệu ban đầu"
				]
			},
			{
				"cell_type": "code",
				"source": [
					"# Hiển thị 5 dòng dữ liệu:\n",
					"df.show(5, False)\n",
					"\n",
					"\n",
					"# Xem cấu trúc dữ liệu:\n",
					"df.printSchema()\n",
					"\n",
					"\n",
					"# Kiểm tra số lượng dòng:\n",
					"print(\"Original rows:\", df.count())"
				],
				"execution_count": 4
			},
			{
				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import col\n",
					"\n",
					"# 1. Loại bỏ NULL\n",
					"clean_df = df.dropna(subset=[\n",
					"    \"tripDistance\",\n",
					"    \"passengerCount\",\n",
					"    \"totalAmount\"\n",
					"])\n",
					"\n",
					"# 2. Loại bỏ chuyến đi không hợp lệ\n",
					"clean_df = clean_df.filter(\n",
					"    (col(\"tripDistance\") > 0) &\n",
					"    (col(\"passengerCount\") > 0)\n",
					")\n",
					"\n",
					"# 3. Loại bỏ giá tiền bất thường\n",
					"clean_df = clean_df.filter(\n",
					"    col(\"totalAmount\") > 0\n",
					")\n",
					"\n",
					"# 4. Loại bỏ outlier\n",
					"clean_df = clean_df.filter(\n",
					"    col(\"tripDistance\") < 100\n",
					")\n",
					"\n",
					"# 5. Kiểm tra\n",
					"print(\"Rows after cleaning:\", clean_df.count())\n",
					"clean_df.show(10, False)"
				],
				"execution_count": 6
			},
			{
				"cell_type": "code",
				"source": [
					"# B5 - Save the Cleaned Data to Data Lake\n",
					"\n",
					"clean_df.write.mode(\"append\").parquet(\n",
					"    \"abfss://datalake@myaccount.dfs.core.windows.net/taxi/cleaned/\"\n",
					")"
				],
				"execution_count": 8
			}
		]
	}
}